# 复制为 .env 后填写。不配置也能以 offline 确定性模式端到端运行。

# ── MiniMax（用于 Agent 推理增强 / 跨模型 CR；OpenAI 兼容端点）──
MINIMAX_API_KEY=
# 区域端点：global -> https://api.minimax.io/v1 ; cn -> https://api.minimaxi.com/v1
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M3

# LLM 提供方：offline（默认，确定性，无网络） | minimax（启用远程增强）
ANKER_LLM_PROVIDER=offline

# ── 媒体资产（概念图/口播，需 `npm i -g mmx-cli` 并已 mmx auth login）──
ANKER_ENABLE_MEDIA=false

# ── 运行参数 ──
ANKER_MAX_RETRIEVAL_ITERS=3
ANKER_HITL=false              # true 时在决策闸 interrupt 等待人工确认
ANKER_TRACE_DIR=runs
